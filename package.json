{
  "name": "@tws/world-forge",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "benchmark:generation": "tsx --tsconfig tsconfig.scripts.json scripts/benchmark-generation.ts",
    "triage:surface": "tsx --tsconfig tsconfig.scripts.json scripts/run-surface-quality-triage.ts",
    "validate:presets": "tsx --tsconfig tsconfig.scripts.json scripts/run-preset-validation.ts",
    "workflow:legacy": "tsx --tsconfig tsconfig.scripts.json scripts/run-generation-workflow.ts",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "validate": "npm run typecheck && npm test",
    "verify": "npm run validate && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "firebase": "^12.15.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.185.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "uuid": "^11.1.1"
  }
}
