{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "baseUrl": "../..",
    "paths": {
      "@world-forge/shared": ["packages/shared/src/index.ts"],
      "@world-forge/renderer": ["packages/renderer/src/index.ts"]
    }
  },
  "references": [{ "path": "../shared" }, { "path": "../renderer" }],
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
