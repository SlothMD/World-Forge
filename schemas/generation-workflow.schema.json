{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threewheeledsloth.com/schemas/generation-workflow.schema.json",
  "title": "Parchment Worlds generation workflow",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "version", "displayName", "defaultFidelity", "stages"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "defaultFidelity": { "enum": ["preview", "standard", "high", "diagnostic"] },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "stageId"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "stageId": { "type": "string", "minLength": 1 },
          "implementationId": { "type": "string" },
          "bodyKind": { "enum": ["star", "rocky", "gas-giant", "ice-giant", "moon", "small-body", "system"] },
          "dependsOn": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "parameters": { "type": "object" },
          "fidelity": { "enum": ["preview", "standard", "high", "diagnostic"] },
          "optional": { "type": "boolean" },
          "enabled": { "type": "boolean" },
          "iterationGroup": { "type": "string" }
        }
      }
    },
    "iterationGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "maxIterations"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "minIterations": { "type": "integer", "minimum": 1 },
          "maxIterations": { "type": "integer", "minimum": 1 },
          "stableForIterations": { "type": "integer", "minimum": 1 },
          "onFailure": { "enum": ["fail", "accept-best-and-warn"] },
          "convergence": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["signal", "deltaBelow"],
              "properties": {
                "signal": { "type": "string", "minLength": 1 },
                "deltaBelow": { "type": "number", "minimum": 0 }
              }
            }
          }
        }
      }
    }
  }
}
